# Database
MONGODB_URI=mongodb://ollamadash:ollamadash123@mongodb:27017/openllm-monitor?authSource=admin
NODE_ENV=production

# Server
PORT=3001
JWT_SECRET=change-me-to-a-secure-secret

# Ollama Configuration
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_CLOUD_URL=https://api.ollama.com
OLLAMA_CLOUD_API_KEY=

# To monitor all Ollama calls, point your apps to the proxy instead of directly to Ollama:
#   Ollama proxy: http://localhost:3001/api/proxy/ollama/api/generate
#   Ollama proxy: http://localhost:3001/api/proxy/ollama/api/chat
#   Ollama Cloud proxy: http://localhost:3001/api/proxy/ollama-cloud/api/chat

# CORS Settings
FRONTEND_URL=http://localhost:4180

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100